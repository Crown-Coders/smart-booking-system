{
  "expo": {
    "name": "Mental.com",
    "slug": "mental-com-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-mental.com.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#002324"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-mental.com.png",
        "backgroundColor": "#002324"
      },
      "usesCleartextTraffic": true,
      "package": "com.mentalcom.mobile"
    },
    "web": {
      "favicon": "./assets/logo-mental.com.png"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "29e423b0-9a13-44e7-9dac-895ca74c483b"
      }
    },
    "owner": "phathisa"
  }
}
